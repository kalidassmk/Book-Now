# BookNow Dashboard — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Redis (must match Spring Boot application.properties)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Spring Boot trading bot API base URL
SPRING_API=http://localhost:8083/api/v1

# Auto-trade defaults (overridden by UI at runtime)
DEFAULT_PROFIT_PCT=1.5
DEFAULT_STOP_LOSS_PCT=0.8
DEFAULT_MAX_POSITIONS=5
DEFAULT_DISPLAY_LIMIT=10
DEFAULT_SIMULATION_MODE=true
