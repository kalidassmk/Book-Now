# Environment Configuration for Analysis Dashboard
# This is the active configuration file

# API Server URL
REACT_APP_API_URL=http://localhost:8000

# API Timeout (milliseconds)
REACT_APP_API_TIMEOUT=10000

# Auto-refresh interval (seconds)
REACT_APP_DEFAULT_REFRESH_INTERVAL=30

# Debug mode default
REACT_APP_DEBUG_MODE=false

# Max articles to display per page
REACT_APP_ARTICLES_PER_PAGE=10

# Pagination
REACT_APP_PAGINATION_ENABLED=true

# App environment
REACT_APP_ENV=development

